#!/data/data/com.termux/files/usr/bin/bash
# setup-termux-shortcut
# Run on Android Termux to create an agent-man launcher shortcut.
# Usage: curl -sL https://raw.githubusercontent.com/FarisZR/agent-man/main/scripts/setup-termux-shortcut | bash

set -euo pipefail

ICON_URL="https://raw.githubusercontent.com/FarisZR/agent-man/main/assets/agent-man-icon.png"
SHORTCUT_NAME="agent-man"
SHORTCUTS_DIR="${HOME}/.termux/widget/dynamic_shortcuts"
ICONS_DIR="${HOME}/.shortcuts/icons"
SSH_CONFIG="${HOME}/.ssh/config"
SSH_DIR="${HOME}/.ssh"

# ── colours ──────────────────────────────────────────────────────────────────
bold=$(tput bold 2>/dev/null || true)
reset=$(tput sgr0 2>/dev/null || true)
green=$(tput setaf 2 2>/dev/null || true)
yellow=$(tput setaf 3 2>/dev/null || true)
cyan=$(tput setaf 6 2>/dev/null || true)

info()    { printf "%s==>%s %s\n" "${cyan}${bold}" "${reset}" "$*"; }
success() { printf "%s✓%s %s\n" "${green}${bold}" "${reset}" "$*"; }
warn()    { printf "%s!%s %s\n" "${yellow}${bold}" "${reset}" "$*"; }

# ── prompt helper ─────────────────────────────────────────────────────────────
ask() {
  local prompt="$1"
  local default="${2:-}"
  local answer
  if [[ -n "$default" ]]; then
    printf "%s%s%s [%s]: " "${bold}" "$prompt" "${reset}" "$default"
  else
    printf "%s%s%s: " "${bold}" "$prompt" "${reset}"
  fi
  read -r answer
  printf '%s' "${answer:-$default}"
}

# ── banner ────────────────────────────────────────────────────────────────────
echo ""
printf "%s agent-man Termux shortcut setup %s\n" "${bold}${cyan}" "${reset}"
echo "────────────────────────────────────────"
echo ""

# ── gather SSH parameters ─────────────────────────────────────────────────────
info "SSH connection details"
echo ""

SSH_HOST=$(ask "Remote hostname or IP" "")
while [[ -z "$SSH_HOST" ]]; do
  warn "Hostname cannot be empty."
  SSH_HOST=$(ask "Remote hostname or IP" "")
done

SSH_USER=$(ask "Remote username" "$(whoami 2>/dev/null || echo user)")
SSH_PORT=$(ask "SSH port" "22")
SSH_KEY=$(ask "Path to SSH private key" "${HOME}/.ssh/id_ed25519")

echo ""

# ── create SSH dir and config ─────────────────────────────────────────────────
info "Configuring SSH..."
mkdir -p "$SSH_DIR"
chmod 700 "$SSH_DIR"

if [[ -f "$SSH_CONFIG" ]] && grep -q "^Host agentbox" "$SSH_CONFIG" 2>/dev/null; then
  warn "~/.ssh/config already contains 'Host agentbox' — skipping SSH config update."
  warn "Edit it manually if the details are wrong: nano ${SSH_CONFIG}"
else
  cat >> "$SSH_CONFIG" <<EOF

Host agentbox
  HostName ${SSH_HOST}
  User ${SSH_USER}
  Port ${SSH_PORT}
  IdentityFile ${SSH_KEY}
  ServerAliveInterval 30
  ServerAliveCountMax 3
EOF
  chmod 600 "$SSH_CONFIG"
  success "SSH config written (Host agentbox → ${SSH_USER}@${SSH_HOST}:${SSH_PORT})"
fi

# ── create shortcut dirs ──────────────────────────────────────────────────────
info "Creating shortcut directories..."
mkdir -p "$SHORTCUTS_DIR"
chmod 700 "$SHORTCUTS_DIR"
mkdir -p "$ICONS_DIR"
chmod -R a-x,u=rwX,go-rwx "$ICONS_DIR"
success "Directories ready"

# ── write shortcut script ─────────────────────────────────────────────────────
info "Writing shortcut script..."
SCRIPT_PATH="${SHORTCUTS_DIR}/${SHORTCUT_NAME}"

cat > "$SCRIPT_PATH" <<'SCRIPT'
#!/data/data/com.termux/files/usr/bin/bash
set -euo pipefail
# bash -l loads ~/.profile so tools like bun are on PATH
ssh -t agentbox 'bash -lc "cd ~/agent-man && ./bin/agent-man-entry"'
SCRIPT

chmod +x "$SCRIPT_PATH"
success "Script written: ${SCRIPT_PATH}"

# ── download icon ─────────────────────────────────────────────────────────────
info "Downloading icon..."
ICON_PATH="${ICONS_DIR}/${SHORTCUT_NAME}.png"

if command -v curl >/dev/null 2>&1; then
  curl -fsSL "$ICON_URL" -o "$ICON_PATH"
elif command -v wget >/dev/null 2>&1; then
  wget -qO "$ICON_PATH" "$ICON_URL"
else
  warn "Neither curl nor wget found — skipping icon download."
  warn "Manually place a PNG at: ${ICON_PATH}"
fi

if [[ -f "$ICON_PATH" ]]; then
  chmod 600 "$ICON_PATH"
  success "Icon saved: ${ICON_PATH}"
fi

# ── done ──────────────────────────────────────────────────────────────────────
echo ""
printf "%s Setup complete! %s\n" "${bold}${green}" "${reset}"
echo "────────────────────────────────────────"
echo ""
echo "To add the launcher shortcut:"
echo ""
echo "  1. Open the Termux:Widget app"
echo "  2. Tap CREATE SHORTCUTS in the Dynamic shortcuts section"
echo "  3. Long-press the Termux:Widget icon on your launcher"
echo "  4. Select 'agent-man' and place it on your home screen"
echo ""
echo "Tap the shortcut to SSH into ${bold}agentbox${reset} and launch agent-man."
echo ""
