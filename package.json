{
  "name": "agent-man",
  "module": "src/index.tsx",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.tsx",
    "start": "bun run src/index.tsx",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "coverage:check": "bun run scripts/check-lcov-thresholds.ts coverage/lcov.info",
    "ci:test": "bun run test:coverage && bun run coverage:check"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/react": "^19.2.14",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@opentui/core": "^0.1.81",
    "@opentui/react": "^0.1.81",
    "react": "^19.2.4"
  }
}
